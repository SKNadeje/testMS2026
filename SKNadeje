    function vypocitejZiskaneBody(tipData, adminVysledky) {
    if (!tipData || !adminVysledky || !adminVysledky.playoff) return 0;
    
    let body = 0;
    const bodovani = { 's32': 2, 's16': 3, 's8': 5, 's4': 8, 'winner': 15 };

    // 1. Kontrola kol pavouka (s32, s16, s8, s4)
    ['s32', 's16', 's8', 's4'].forEach(faze => {
        const adminTymy = adminVysledky.playoff[faze] || [];
        const tipTymy = tipData[faze] || [];
        
        if (adminTymy.length > 0) {
            adminTymy.forEach(tym => {
                // Pokud tým, který postoupil v reálu, má hráč ve svém tipu v dané fázi
                if (tym && tipTymy.includes(tym)) {
                    body += bodovani[faze];
                }
            });
        }
    });

    // 2. Kontrola vítěze
    if (adminVysledky.playoff.winner && tipData.winner === adminVysledky.playoff.winner) {
        body += bodovani.winner;
    }

    return body;
}
    
