   async function togglePayment(rowId, currentStatus) {
    // --- 🔒 OCHRANA ADMIN HESLEM 🔒 ---
    // Zastavíme každého, kdo klikne, a vynutíme heslo
    const heslo = prompt("Tato akce je pouze pro admina. Zadej heslo:");
    
    // TADY SI ZMĚŇ HESLO NA NĚJAKÉ SVOJE
    if (heslo !== "Matysek.2019") {
        alert("❌ Nesprávné heslo! Úprava platby zamítnuta.");
        return; // Okamžitě ukončí funkci, zbytek kódu se vůbec nespustí
    }
    // ----------------------------------

    console.log("1. Kliknuto! Spouštím úpravu pro ID:", rowId, "Současný stav:", currentStatus);
    const novyStatus = !currentStatus; 
    
    if (!confirm(`Opravdu chceš hráči změnit platbu na: ${novyStatus ? "ZAPLACENO" : "NEZAPLACENO"}?`)) {
        return; 
    }

    try {
        console.log("2. Posílám požadavek do Supabase...");
        
        // Přidali jsme .select(), aby nám Supabase vrátila upravený řádek (pokud se to povede)
        const { data, error } = await supabaseClient
            .from('tipy')
            .update({ paid: novyStatus })
            .eq('user_id', rowId)
            .select(); 

        console.log("3. Odpověď ze Supabase - Upravená data:", data, "Chyba:", error);

        if (error) throw error;

