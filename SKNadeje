async function updateRankTrends() {
    const heslo = prompt("Zadej administrátorské heslo pro trendy:");
    if (heslo !== "Matysek.2019") return alert("Přístup zamítnut!");

    const btn = document.getElementById('btn-update-trends');
    const originalText = btn.innerHTML;
    
    // Loading stav
    btn.disabled = true;
    btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Počítám ranky...';

    try {
        // 1. Načteme všechna data
        const { data: tipy, error: err1 } = await supabaseClient.from('tipy').select('*');
        const { data: real, error: err2 } = await supabaseClient.from('admin_vysledky').select('*').eq('id', 1).single();

        if (err1 || err2) throw new Error("Nepodařilo se spojit s databází.");

        // 2. Logika výpočtu bodů (musí být stejná jako v žebříčku)
        const r = real.playoff ? { ...real.playoff, groups: real.groups } : real;
        
        const rankedPlayers = tipy.map(p => {
            let tip = p.tip_data;
            if (typeof tip === 'string') tip = JSON.parse(tip);
            if (!tip) tip = {};

            let pts = 0;
            // Skupiny (4 body za přesné umístění)
            if (r.groups && tip.groups) {
                r.groups.forEach((g, i) => {
                    const tipG = tip.groups[i] || [];
                    const aT = g.teams || g;
                    if (Array.isArray(aT)) {
                        aT.forEach((t, pos) => { if (t && tipG[pos] && String(t).trim() === String(tipG[pos]).trim()) pts += 4; });
                    }
                });
            }
            // Playoff (body za účast týmu v daném kole)
            const ck = (sid, val) => {
                const rt = r[sid] || [];
                const tt = tip[sid] || [];
                if (Array.isArray(rt)) rt.forEach(t => { if (t && Array.isArray(tt) && tt.some(x => String(x).trim() === String(t).trim())) pts += val; });
            };
            ck('s32', 2); ck('s16', 3); ck('s8', 4); ck('s4', 5);
            if (r.winner && tip.winner && String(r.winner).trim() === String(tip.winner).trim()) pts += 12;
            if (r.bronze && tip.bronze && String(r.bronze).trim() === String(tip.bronze).trim()) pts += 8;

            return { id: p.id, points: pts };
        });

        // 3. Seřazení hráčů podle bodů (vytvoření pořadí)
        rankedPlayers.sort((a, b) => b.points - a.points);

        // 4. Hromadný update do Supabase (previous_rank)
        console.log("Zapisuji nové trendy do DB...");
        for (let i = 0; i < rankedPlayers.length; i++) {
            const currentRank = i + 1;
            await supabaseClient
                .from('tipy')
                .update({ previous_rank: currentRank })
                .eq('id', rankedPlayers[i].id);
        }

        alert("Hotovo! Pořadí bylo uloženo jako výchozí bod pro šipky.");
        if (typeof loadAll === "function") await loadAll(); // Obnovit žebříček

    } catch (err) {
        console.error(err);
        alert("Chyba: " + err.message);
    } finally {
        btn.disabled = false;
        btn.innerHTML = originalText;
    }
}    


// Tuto funkci zavoláš v adminu ve chvíli, kdy klikneš na "Vyhodnotit"
// Jako parametr 'adminVysledky' jí předáš ten svůj uložený objekt s reálnými výsledky
async function vyhodnotitTipy(adminVysledky) {
    const { data: vsechnyTipy, error: fetchError } = await supabaseClient
        .from('tipy')
        .select('*');

    if (fetchError) {
        console.error("Chyba při načítání tipů z DB:", fetchError);
        return;
    }

    let pocetVyhodnocenych = 0;

    for (const radek of vsechnyTipy) {
        let celkoveBody = 0;
        const userTip = radek.tip_data;

        // --- 1. SKUPINY (4 body za přesné umístění) ---
        if (userTip.groups && adminVysledky.groups) {
            adminVysledky.groups.forEach((adminSkupina, i) => {
                const userSkupina = userTip.groups[i] || [];
                adminSkupina.forEach((tym, j) => {
                    if (tym && userSkupina[j] === tym) celkoveBody += 4;
                });
            });
        }

        // --- 2. PAVOUK (Body za účast týmu v daném kole) ---
        // Definujeme si kola a jejich bodovou hodnotu
        const kola = [
            { klic: 's32', body: 2 },
            { klic: 's16', body: 3 },
            { klic: 's8',  body: 4 },
            { klic: 's4',  body: 5 }
        ];

        kola.forEach(kolo => {
            const adminTymy = adminVysledky[kolo.klic] || [];
            const userTymy = userTip[kolo.klic] || [];
            
            // Za každý tým, který uživatel "poslal" do tohoto kola a reálně tam je
            adminTymy.forEach(tym => {
                if (tym && userTymy.includes(tym)) {
                    celkoveBody += kolo.body;
                }
            });
        });

        // --- 3. BRONZ (8 bodů za přesnou trefu) ---
        if (userTip.bronze && adminVysledky.bronze) {
            if (userTip.bronze === adminVysledky.bronze) celkoveBody += 8;
        }

        // --- 4. CELKOVÝ VÍTĚZ (12 bodů za přesnou trefu) ---
        if (userTip.winner && adminVysledky.winner) {
            if (userTip.winner === adminVysledky.winner) celkoveBody += 12;
        }

        // Zápis do databáze
        const { error: updateError } = await supabaseClient
            .from('tipy')
            .update({ body: celkoveBody })
            .match({ id: radek.id });

        if (!updateError) pocetVyhodnocenych++;
    }

    alert(`Úspěšně vyhodnoceno! Body rozděleny pro ${pocetVyhodnocenych} hráčů.`);
    
    // Po vyhodnocení hned aktualizujeme tabulku na webu
    if (typeof nactiZebricek === "function") nactiZebricek();
}
    

