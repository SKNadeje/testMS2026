async function renderLeaderboard(data, real) {
    console.log("🚀 START: renderLeaderboard (Full Detail Mode + Bank)", { pocet_tipu: data?.length });
    
    const body = document.getElementById('public-body');
    if (!body) return;

    // --- 👤 ZÍSKÁNÍ UŽIVATELE ---
    let loggedUserId = null;
    try {
        const { data: authData } = await supabaseClient.auth.getUser();
        if (authData?.user) loggedUserId = authData.user.id;
    } catch (e) { console.warn("Uživatel nepřihlášen."); }

    // --- 🕒 KONTROLA DEADLINE ---
    const isBeforeDeadline = new Date().getTime() < new Date("2026-06-11T20:00:00").getTime();

    // --- 📦 DATA ADMINA A VÝPOČET BODŮ ---
    const adminData = real || window.currentResults || {};
    const r = adminData.playoff ? { ...adminData.playoff, groups: adminData.groups } : adminData;

    const processed = (data || []).map(row => {
        let tip = row.tip_data;
        if (typeof tip === 'string') { try { tip = JSON.parse(tip); } catch(e) { tip = {}; } }
        if (!tip) tip = {};
        
        let pts = 0;
        // Bodování skupin
        if (r.groups && tip.groups) {
            r.groups.forEach((g, i) => {
                const tipG = tip.groups[i] || [];
                const aTeams = g.teams || g;
                if (Array.isArray(aTeams)) {
                    aTeams.forEach((team, pos) => {
                        if (team && tipG[pos] && String(team).trim() === String(tipG[pos]).trim()) pts += 4;
                    });
                }
            });
        }
        // Bodování playoff
        const ck = (sid, p) => {
            const rt = r[sid] || [];
            const tt = tip[sid] || [];
            if (Array.isArray(rt)) rt.forEach(t => { if (t && Array.isArray(tt) && tt.some(x => String(x).trim() === String(t).trim())) pts += p; });
        };
        ck('s32', 2); ck('s16', 3); ck('s8', 4); ck('s4', 5);
        if (r.winner && tip.winner && String(r.winner).trim() === String(tip.winner).trim()) pts += 12;
        if (r.bronze && tip.bronze && String(r.bronze).trim() === String(tip.bronze).trim()) pts += 8;

        return { ...row, tip, points: pts };
    }).sort((a, b) => b.points - a.points);

    // --- 🎨 POMOCNÉ FUNKCE PRO BARVY ---
    const getStatusClass = (stageId, teamName, stageCount) => {
        const aS = r[stageId] || [];
        if (!teamName) return ''; 
        const valid = Array.isArray(aS) ? aS.filter(t => t && t.trim() !== "") : [];
        if (valid.length === 0) return 'status-pending';
        if (valid.some(t => String(t).trim() === String(teamName).trim())) return 'status-correct';
        return (valid.length >= stageCount) ? 'status-wrong' : 'status-pending';
    };

    // --- 🖌️ RENDEROVÁNÍ TABULKY ---
    let lastPoints = -1;
    let currentRank = 0;

    body.innerHTML = processed.map((player, i) => {
        if (player.points !== lastPoints) { currentRank = i + 1; }
        lastPoints = player.points;

        const rowId = player.user_id || player.id;
        const isOwn = loggedUserId && String(loggedUserId) === String(rowId);
        const canSee = !isBeforeDeadline || isOwn;
        const isPaid = player.paid === true || player.paid === 1 || String(player.paid) === 'true';

        // Trendy (Šipky)
        let trend = '<span style="color:#64748b; margin-left:8px; font-size:0.75rem;">-</span>';
        if (player.previous_rank) {
            const diff = player.previous_rank - currentRank;
            if (diff > 0) trend = `<span style="color:#10b981; margin-left:8px; font-size:0.75rem;"><i class="fas fa-arrow-up"></i> ${diff}</span>`;
            else if (diff < 0) trend = `<span style="color:#ef4444; margin-left:8px; font-size:0.75rem;"><i class="fas fa-arrow-down"></i> ${Math.abs(diff)}</span>`;
        }

        // Barvy pro top 3
        let nameStyle = "color:#f8fafc;";
        let rowStyle = "";
        if (currentRank === 1) { nameStyle = "color:#fbbf24;"; rowStyle = "background:rgba(251,191,36,0.05); border-left:4px solid #fbbf24;"; }
        else if (currentRank === 2) { nameStyle = "color:#cbd5e1;"; rowStyle = "border-left:4px solid #cbd5e1;"; }
        else if (currentRank === 3) { nameStyle = "color:#cd7f32;"; rowStyle = "border-left:4px solid #cd7f32;"; }

        return `
            <tr class="player-row" ${canSee ? `onclick="toggleDetail('det-${rowId}')"` : ""} style="cursor:${canSee ? 'pointer':'default'}; ${rowStyle}">
                <td style="width:75px; padding-left:15px; font-weight:bold; ${nameStyle}">${currentRank}.${trend}</td>
                <td style="padding:12px 0;">
                    <div style="font-weight:800; ${nameStyle} display:flex; align-items:center; gap:8px;">
                        ${player.name || 'Anonym'} ${!canSee ? '🔒' : ''}
                        <span onclick="event.stopPropagation(); togglePayment('${rowId}', ${isPaid})" 
                              style="padding:2px 6px; border-radius:4px; font-size:0.6rem; background:${isPaid ? '#10b981':'#ef4444'}; color:white; cursor:pointer;">
                            ${isPaid ? 'ZAPLACENO' : 'DLUŽÍ'}
                        </span>
                    </div>
                </td>
                <td style="text-align:right; padding-right:15px; font-weight:900; color:var(--accent);">${player.points} PTS</td>
            </tr>
            ${canSee ? `
            <tr id="det-${rowId}" class="tip-detail-row" style="display:none; background:#0f172a;">
                <td colspan="3" style="padding:20px;">
                    <div style="border-left:4px solid #1e293b; padding-left:20px;">
                        <span style="color:var(--accent); font-weight:bold; font-size:0.75rem; text-transform:uppercase;">Skupiny</span>
                        <div class="det-groups-grid" style="margin-top:10px;">
                            ${(player.tip.groups||[]).map((g, idx) => {
                                const adminG = r.groups && r.groups[idx];
                                const aTeams = adminG?.teams || adminG;
                                return `
                                    <div class="det-group-box">
                                        <b>Sk. ${String.fromCharCode(65+idx)}</b>
                                        ${g.map((t, p) => {
                                            let c = (aTeams && aTeams[p] && String(aTeams[p]).trim() === String(t).trim()) ? 'status-correct' : 'status-wrong';
                                            if (!aTeams || !aTeams[p]) c = '';
                                            return `<div class="${c}" style="font-size:0.8rem; margin:1px 0;">${p+1}. ${t}</div>`;
                                        }).join('')}
                                    </div>`;
                            }).join('')}
                        </div>

                        <span style="color:var(--winner); font-weight:bold; font-size:0.75rem; text-transform:uppercase; display:block; margin-top:20px;">Play-off</span>
                        <div class="det-playoff-stages" style="margin-top:10px;">
                            <div class="det-stage-column">
                                <div class="det-stage-card"><h5>1/16</h5><div>${(player.tip.s32||[]).map(t => `<span class="det-team-tag ${getStatusClass('s32', t, 16)}">${t}</span>`).join('')}</div></div>
                                <div class="det-stage-card"><h5>1/8</h5><div>${(player.tip.s16||[]).map(t => `<span class="det-team-tag ${getStatusClass('s16', t, 8)}">${t}</span>`).join('')}</div></div>
                            </div>
                            <div class="det-stage-column">
                                <div class="det-stage-card"><h5>1/4</h5><div>${(player.tip.s8||[]).map(t => `<span class="det-team-tag ${getStatusClass('s8', t, 4)}">${t}</span>`).join('')}</div></div>
                                <div class="det-stage-card"><h5>1/2</h5><div>${(player.tip.s4||[]).map(t => `<span class="det-team-tag ${getStatusClass('s4', t, 4)}">${t}</span>`).join('')}</div></div>
                            </div>
                            <div class="det-stage-column">
                                <div class="det-stage-card" style="border-top:2px solid #cd7f32; background:rgba(205,127,50,0.05);">
                                    <h5 style="color:#cd7f32;">🥉 3. Místo</h5>
                                    <div class="det-team-tag ${getStatusClass('bronze', player.tip.bronze, 1)}">${player.tip.bronze || '--'}</div>
                                </div>
                                <div class="det-stage-card" style="border-top:2px solid gold; margin-top:10px; background:rgba(251,191,36,0.05);">
                                    <h5 style="color:gold;">🥇 Vítěz</h5>
                                    <div class="det-team-tag ${getStatusClass('winner', player.tip.winner, 1)}">${player.tip.winner || '--'}</div>
                                </div>
                            </div>
                        </div>
                    </div>
                </td>
            </tr>` : ''}
        `;
    }).join('');

    // --- 💰 AKTUALIZACE BANKU (Jen od zaplacených hráčů) ---
const bankEl = document.getElementById('currentBank');
