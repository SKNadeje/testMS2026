function cfS(sid, count) {
    const wins = [...document.querySelectorAll(`#sec-${sid} .selected`)].map(e => e.innerText);
    const loss = [...document.querySelectorAll(`#sec-${sid} .matchup`)].map(m => { 
        const t = m.querySelectorAll('.playoff-team'); 
        return t[0].classList.contains('selected') ? t[1].innerText : t[0].innerText; 
    });

    if(wins.length < count) return alert("Vyber vítěze všech zápasů!");
    
    state.playoff[sid] = wins;

    // Reset budoucích kol při změně výsledku (maže staré tipy v pavouku)
    const order = ['s32', 's16', 's8', 's4', 's3', 's2'];
    let idx = order.indexOf(sid);
    for(let i = idx + 1; i < order.length; i++) {
        if(state.history) delete state.history[order[i]]; 
        const nextDiv = document.getElementById(`sec-${order[i]}`);
        if(nextDiv) nextDiv.remove();
    }

    // --- LOGIKA POSTUPU MEZI KOLY ---
    // Poznámka: genStage v sobě už má nový scroll-fix, takže tady ho nemusíme volat extra
    if(sid === 's32') {
        genStage('Osmifinále (1/8)', wins, 8, 's16', 'sec-s32', 'dot-s32');
    } 
    else if(sid === 's16') {
        genStage('Čtvrtfinále', wins, 4, 's8', 'sec-s16', 'dot-s16');
    } 
    else if(sid === 's8') {
        genStage('Semifinále', wins, 2, 's4', 'sec-s8', 'dot-s8');
    } 
    else if(sid === 's4') {
        // Aktivujeme stepper pro finálovou část
        const dot4 = document.getElementById('dot-s4');
        if(dot4) dot4.classList.add('active'); 
        
        // Zápas o 3. místo
        genStage('O 3. Místo', loss, 1, 's3', 'sec-s4', 'dot-s4'); 
    } 
    else if(sid === 's3') {
        const finalists = state.playoff['s4']; // Vítězové ze semifinále
        genStage('Finále', finalists, 1, 's2', 'sec-s3', 'dot-s3');
    } 
