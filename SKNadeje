<script>

function showPaymentModal(playerName) {
    const modal = document.getElementById('payment-modal-overlay');
    const qrContainer = document.getElementById('qr-code-container');
    
    // 1. Očista jména (jen odstraníme háčky a čárky, mezery Paylibo zvládne)
    const cleanName = playerName.normalize("NFD").replace(/[\u0300-\u036f]/g, "").substring(0, 15);
    
    // 2. OFICIÁLNÍ ČESKÉ API PRO QR PLATBU (Samo řeší IBAN, formát i Air Bank vrtochy)
    const qrUrl = `https://api.paylibo.com/paylibo/generator/czech/image?accountNumber=295511827&bankCode=0300&amount=200.00&currency=CZK&message=${encodeURIComponent('WC26 ' + cleanName)}&size=400`;

    if (qrContainer) {
        qrContainer.innerHTML = `
            <div style="display: flex; flex-direction: column; align-items: center; width: 100%;">
                
                <div style="background: white; padding: 40px; border-radius: 20px; box-shadow: 0 15px 45px rgba(0,0,0,0.7); margin-bottom: 25px; display: inline-block;">
                    <img src="${qrUrl}" alt="QR Platba" 
                         style="display: block; width: 260px; height: 260px; image-rendering: pixelated; border: 1px solid #eee;">
                    <div style="color: #000; font-family: sans-serif; font-weight: 900; font-size: 14px; margin-top: 20px; text-align: center; letter-spacing: 4px; opacity: 0.5;">QR PLATBA</div>
                </div>

                <div style="background: rgba(255,255,255,0.05); padding: 20px; border-radius: 12px; width: 100%; max-width: 340px; border: 1px solid rgba(255,255,255,0.1); text-align: left; box-sizing: border-box;">
                    <div style="color: #fbbf24; font-size: 0.75rem; font-weight: 800; text-transform: uppercase; margin-bottom: 12px; border-bottom: 1px solid rgba(255,255,255,0.1); padding-bottom: 5px;">Platební instrukce</div>
                    
                    <div style="margin-bottom: 8px; display: flex; justify-content: space-between; font-size: 1rem;">
                        <span style="opacity: 0.7;">Částka:</span>
                        <b style="color: #22c55e;">200 Kč</b>
                    </div>
                    
                    <div style="margin-bottom: 8px; display: flex; flex-direction: column;">
                        <span style="opacity: 0.7; font-size: 0.8rem;">Číslo účtu:</span>
                        <b style="font-family: monospace; letter-spacing: 0.5px;">295511827 / 0300</b>
                    </div>
                    
                    <div style="display: flex; flex-direction: column;">
                        <span style="opacity: 0.7; font-size: 0.8rem;">Zpráva (Poznámka):</span>
                        <b style="color: #fff; font-size: 1.1rem; border-left: 3px solid #fbbf24; padding-left: 8px; margin-top: 4px;">WC26 ${playerName}</b>
                    </div>
                </div>
            </div>
        `;
    }

    if (modal) {
        modal.style.display = 'flex';
        modal.style.setProperty('display', 'flex', 'important');
    }
}


    
