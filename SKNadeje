    if (index > -1) {
        // Tým už je vybraný -> SMAŽEME HO
        state.thirds.splice(index, 1);
    } else {
        // Tým není vybraný -> PŘIDÁME HO (pokud jich není 8)
        if (state.thirds.length < 8) {
            state.thirds.push(name);
        } else {
            alert("Můžeš vybrat maximálně 8 týmů ze 3. míst.");
            return;
        }
    }

    // 3. KOMPLETNÍ PŘEKRESLENÍ VŠECH KARET (To vyřeší to číslování)
    // Projdeme všechny karty s třídou .card-third
