    const { data: { session } } = await supabaseClient.auth.getSession();
    
    const authSection = document.getElementById('auth-section');
    const loggedInSection = document.getElementById('logged-in-section');
    const userDisplay = document.getElementById('user-email-display');

    if (session) {
        // 2. Teď se musíme podívat do tabulky 'tipy', jestli tam uživatel už nemá jméno
        // Používáme session.user.id, abychom našli ten správný řádek
        const { data: tipData } = await supabaseClient
            .from('tipy')
            .select('name')
            .eq('user_id', session.user.id)
            .maybeSingle(); // Vrátí buď jeden řádek, nebo null

        // 3. Připravíme si text jména (pokud existuje)
        const nameSuffix = (tipData && tipData.name) ? ` (${tipData.name})` : "";

        // 4. Nastavíme viditelnost sekcí
        if (authSection) authSection.classList.add('hidden');
        if (loggedInSection) loggedInSection.classList.remove('hidden');
        
        // 5. Vypíšeme email + jméno
        if (userDisplay) {
            userDisplay.innerText = session.user.email + nameSuffix;
        }

        // Tady pravděpodobně voláš další funkce jako loadMyTip() atd.
    } else {
        // Uživatel NENÍ přihlášený
        if (authSection) authSection.classList.remove('hidden');
        if (loggedInSection) loggedInSection.classList.add('hidden');
    }
}

async function nactiUzivatelskyTip(userId) {
    console.log("➡️ [Tip] 1. Začínám stahovat tvůj tip pro pavouka...");
    
    try {
        const { data, error } = await supabaseClient
            .from('tipy')
            .select('name, tip_data') // Přidali jsme 'name', aby se ti jméno samo vyplnilo
            .eq('user_id', userId)
            .maybeSingle();

        if (error) throw error;

        if (data) {
            // 0. PŘEDVYPLNĚNÍ JMÉNA
            if (data.name) {
                const nameInput = document.getElementById('user-name');
                if (nameInput) nameInput.value = data.name;
            }

            if (data.tip_data) {
                console.log("➡️ [Tip] 2. Mám data z DB, plním proměnnou state...");
                const tip = data.tip_data;
                
                // 1. NAPLNĚNÍ A PŘEKRESLENÍ SKUPIN
                if (tip.groups) {
                    tip.groups.forEach((tymy, i) => {
                        if (state.groups[i]) {
                            state.groups[i].teams = tymy;
                            if (tymy && tymy.length > 0) {
                                state.groups[i].done = true; 
                                
                                // --- TADY JE TA ZMĚNA VZHLEDU ---
                                // Zavoláme naši novou funkci, která kartu stylově přeskládá
                                if (typeof aktualizujVzhledKarty === "function") {
                                    aktualizujVzhledKarty(state.groups[i].id);
                                }
                                // ---------------------------------
                            }
                        }
                    });
                }
                
                // ... (zbytek tvé funkce pokračuje beze změny: 2. NAPLNĚNÍ PAVOUKA atd.) ...
                
                // 2. NAPLNĚNÍ PAVOUKA (Playoff)
                if (state.playoff) Object.assign(state.playoff, tip);

                console.log("➡️ [Tip] 3. Generuji HTML a simuluji tvé klikání na 3. místa...");
                
                // 3. CHYTRÁ SIMULACE 3. MÍST
                if (tip.thirds && tip.thirds.length === 8) {
                    state.thirds = []; 
                    if (typeof confirmAllGroups === "function") confirmAllGroups();
                    
                    tip.thirds.forEach(teamName => {
                        document.querySelectorAll('.card-third').forEach(card => {
                            const onclickAttr = card.getAttribute('onclick') || "";
                            if (onclickAttr.includes(teamName)) {
                                if (typeof selectThird === "function") selectThird(card, teamName);
                            }
                        });
                    });
                    
                    if (typeof confirmThirds === "function") confirmThirds();
                    
                    // --- NÁVRAT ZPĚT NA SKUPINY ---
                    const groupsDiv = document.getElementById('phase-groups');
                    const thirdsDiv = document.getElementById('phase-thirds') || document.getElementById('sec-thirds');
                    const playoffCont = document.getElementById('playoff-container');
                    
                    if (groupsDiv) groupsDiv.classList.remove('hidden');
                    if (thirdsDiv) thirdsDiv.classList.add('hidden');
                    if (playoffCont) playoffCont.classList.add('hidden');
                    
                    if (typeof updateStepper === "function") updateStepper('dot-s1');
                    window.scrollTo(0, 0);
                    
                    console.log("✅ [Tip] 4. HOTOVO!");
                } else {
                    console.log("ℹ️ [Tip] Tip není kompletní, nechávám tě na skupinách.");
                }
            } // Konec if (data.tip_data)
        } // Konec if (data)
    } catch (err) {
        console.error("🛑 [Tip] Kritická chyba při načítání tipu:", err);
    }
}
    
supabaseClient.auth.onAuthStateChange((event, session) => {
    console.log("🔔 AUTH EVENT:", event);

    // FÍGL: Dáme Supabase 100 milisekund pauzu, než začneme tahat data, 
    // aby se nezasekl na zpracování přihlášení (deadlock).
    setTimeout(async () => {
        console.log("🔍 Zkouším volat žebříček (po krátké pauze)...");
        try {
            if (typeof loadAll === "function") {
                await loadAll();
            }
        } catch (err) {
            console.error("❌ Chyba v loadAll:", err);
        }

        const authSec = document.getElementById('auth-section');

       if (session) {
            console.log("👤 Přihlášen ID:", session.user.id);
            try {
                if (typeof nactiUzivatelskyTip === "function") {
                    await nactiUzivatelskyTip(session.user.id);
                } else {
                    // Tady na nás teď vyskočí obří chyba, pokud funkce chybí
                    console.error("❌ POZOR: Funkce nactiUzivatelskyTip() není v kódu k nalezení!");
                }
            } catch (err) {
                console.error("❌ Chyba v nactiUzivatelskyTip:", err);
            }
            if (authSec) authSec.classList.add('hidden');
        }
       
    else {
            console.log("👤 Nepřihlášen.");
            if (authSec) authSec.classList.remove('hidden');
        }
    }, 100); // <-- Těch 100ms je ten klíčový detail
});

// --- DYNAMICKÉ PŘESKLÁDÁNÍ NAVIGACE (MOBIL VS PC) ---
function srovnejNavigaci() {
    // 1. Najdeme správné prvky
    const navigace = document.querySelector('.step-indicator'); 
    const mainSekce = document.querySelector('main'); 
    
    // TADY JE OPRAVA: Hledáme header, který je uvnitř tvé hlavní aplikace, ne ten s vlajkami!
    const spravnaHlavicka = document.querySelector('.app-wrapper header'); 

    if (!navigace || !mainSekce || !spravnaHlavicka) return;

    // 2. Kontrola šířky (1200px je tvůj zlomový bod v CSS)
    if (window.innerWidth <= 1200) {
        // Na mobilu: Přesuneme bubliny těsně nad <main> 
        mainSekce.parentNode.insertBefore(navigace, mainSekce);
        navigace.style.marginTop = '20px'; 
    } else {
        // Na počítači: Vrátíme bubliny zpět pod nadpis MS 2026 TIPOVAČKA
        spravnaHlavicka.appendChild(navigace);
        navigace.style.marginTop = '0';
    }
}

// Spustíme to hned po načtení stránky a při každé změně velikosti okna
window.addEventListener('DOMContentLoaded', () => {
    srovnejNavigaci();
    window.addEventListener('resize', srovnejNavigaci);
});
    
// Spustíme kontrolu hned po načtení stránky
