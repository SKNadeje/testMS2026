/* --- 1. ODPOČET (Synchronizovaný pro všechna místa) --- */
function initCountdown() {
    // MS 2026 začíná 11. června 2026 ve 21:00
    const deadline = new Date("2026-06-11T21:00:00").getTime();

    const timerInterval = setInterval(function() {
        const now = new Date().getTime();
        const distance = deadline - now;

        const btnOdeslat = document.getElementById('btn-odeslat-tip'); 
        const btnUpravit = document.getElementById('btn-upravit-tip');

        if (distance < 0) {
            clearInterval(timerInterval);
            
            // Schováme všechny běžící timery (pomocí třídy nebo ID)
            document.querySelectorAll("#countdown-timer, .countdown-numbers").forEach(el => el.style.display = "none");
            document.querySelectorAll("#countdown-expired, .countdown-expired").forEach(el => el.style.display = "block");

            // Zablokování tlačítek pro odeslání/úpravu
            [btnOdeslat, btnUpravit].forEach(btn => {
                if (btn) {
                    btn.disabled = true;
                    btn.style.opacity = "0.3";
                    btn.style.cursor = "not-allowed";
                    btn.innerText = "Tipování skončilo";
                }
            });
        } else {
            // Výpočet zbývajícího času
            const days = Math.floor(distance / (1000 * 60 * 60 * 24)).toString().padStart(2, '0');
            const hours = Math.floor((distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60)).toString().padStart(2, '0');
            const minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60)).toString().padStart(2, '0');
            const seconds = Math.floor((distance % (1000 * 60)) / 1000).toString().padStart(2, '0');

            // Aktualizace všech elementů na stránce, které mají tvoje ID
            // (Pokud máš ID na více místech, doporučuji změnit na querySelectorAll('.cd-days'))
            const updateText = (id, val) => {
                const elements = document.querySelectorAll(`#${id}, .${id}`);
                elements.forEach(el => el.innerText = val);
            };

            updateText("cd-days", days);
            updateText("cd-hours", hours);
            updateText("cd-mins", minutes);
            updateText("cd-secs", seconds);
        }
    }, 1000);
}

