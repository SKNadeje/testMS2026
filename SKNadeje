    .pts-pill { background: linear-gradient(145deg, #1e293b, #0f172a); padding: 6px 16px; border-radius: 10px; border: 1px solid rgba(255,255,255,0.05); box-shadow: 0 4px 10px rgba(0,0,0,0.3); display: inline-block; }
    #thirds-counter { background: linear-gradient(135deg, #fbbf24, #d97706) !important; color: #000 !important; padding: 6px 20px; border-radius: 10px; font-weight: 900; font-size: 1.3rem; min-width: 80px; text-align: center; display: inline-block; box-shadow: 0 4px 15px rgba(251, 191, 36, 0.3);}

    /* --- AUTH & LEGEND --- */
